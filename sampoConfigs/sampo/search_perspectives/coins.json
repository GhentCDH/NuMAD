{
    "id": "coins",
    "endpoint": {
        "url": "",
        "useAuth": false,
        "prefixesFile": "prefixes.js",
        "defaultSparql": true
    },
    "generalQueries": {
        "facetResultSetQuery": "facetResultSetQueryOntop"
    },
    "sparqlQueriesFile": "coins.js",
    "baseURI": "http://numad.ugent.be/resource",
    "URITemplate": "<BASE_URI>/coin/<LOCAL_ID>",
    "facetClass": "nmo:Find",
    "frontPageImage": "main_page/mmm-banner.jpg",
    "searchMode": "faceted-search",
    "enableDynamicLanguageChange": false,
    "defaultActiveFacets": [],
    "defaultTab": "table",
    "defaultInstancePageTab": "table",
    "resultClasses": {
        "coins": {
            "paginatedResultsConfig": {
                "tabID": 0,
                "component": "ResultTable",
                "tabPath": "table",
                "tabIcon": "CalendarViewDay",
                "propertiesQueryBlock": "coinProperties",
                "pagesize": 100,
                "sortBy": null,
                "sortDirection": null
            },
            "instanceConfig": {
                "propertiesQueryBlock": "coinProperties",
                "instancePageResultClasses": {
                    "instancePageTable": {
                        "tabID": 0,
                        "component": "InstancePageTable",
                        "tabPath": "table",
                        "tabIcon": "CalendarViewDay"
                    }
                }
            }
        },
        "findsPlaces": {
            "tabID": 1,
            "tabPath": "map",
            "tabIcon": "AddLocation",
            "component": "LeafletMap",
            "showInstanceCountInClusters": false,
            "showExternalLayers": true,
            "customMapControl": true,
            "sparqlQuery": "coinPlaces",
            "filterTarget": "id",
            "facetClass": "coins",
            "resultMapper": "mapPlaces",
            "instanceConfig": {
                "propertiesQueryBlock": "coinProperties",
                "createPopUpContent": "createPopUpContentDefault"
            },
            "customTilesLayer": {
                "type": "pmtiles",
                "inConfig": true,
                "url": "maps/map.pmtiles",
                "maxZoom": 14,
                "minZoom": 8
            }
        },
        "findsPlacesHeatmap": {
            "tabID": 2,
            "tabPath": "heatmap",
            "tabIcon": "BubbleChart",
            "component": "Deck",
            "layerType": "heatmapLayer",
            "sparqlQuery": "coinPlaces",
            "facetClass": "coins",
            "filterTarget": "id",
            "resultMapper": "mapPlaces",
            "customTilesLayer": {
                "type": "pmtiles",
                "inConfig": true,
                "url": "maps/map.pmtiles"
            }
        },
        "mintsPlacesHeatmap": {
            "tabID": 3,
            "tabPath": "mintsheatmap",
            "tabIcon": "BubbleChart",
            "component": "Deck",
            "layerType": "heatmapLayer",
            "sparqlQuery": "mintPlaces",
            "facetClass": "coins",
            "filterTarget": "id",
            "resultMapper": "mapPlaces",
            "customTilesLayer": {
                "type": "pmtiles",
                "inConfig": true,
                "url": "maps/map.pmtiles"
            }
        },
        "coinsMigrations": {
            "tabID": 4,
            "component": "Deck",
            "tabPath": "migrations",
            "tabIcon": "Redo",
            "sparqlQuery": "migrations",
            "facetClass": "coins",
            "filterTarget": "coin",
            "resultMapper": "makeObjectList",
            "layerType": "arcLayer",
            "arcWidthVariable": "instanceCountScaled",
            "instanceVariable": "coin",
            "showTooltips": false,
            "postprocess": {
                "func": "linearScale",
                "config": {
                    "variable": "instanceCount",
                    "minAllowed": 2,
                    "maxAllowed": 20
                }
            },
            "customTilesLayer": {
                "type": "pmtiles",
                "inConfig": true,
                "url": "maps/map.pmtiles"
            }
        },
        "coinsMigrationsDialog": {
            "sparqlQuery": "migrationsDialog",
            "filterTarget": "id",
            "resultMapper": "makeObjectList"
        }
    },
    "maps": {
