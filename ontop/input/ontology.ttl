@prefix :     <http://numad.ugent.be/resource/> .
@prefix nmd:  <http://numad.ugent.be/ontology#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix nmo:  <http://nomisma.org/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

nmd:
    a               owl:Ontology ;
    rdfs:label      "NuMAD Ontology"@en ;
    rdfs:comment    "Ontology for NuMAD"@en ;
    dct:creator     "NuMAD Project" ;
    dct:description "An ontology for representing extra concepts for coin finds not yet present in nomisma"@en .


##############
# CLASSES
##############
nmd:Identifier
    a               owl:Class ;
    rdfs:subClassOf foaf:Person ;
    rdfs:label      "Identifier"@en ;
    rdfs:comment    "A person who identified one or multiple coins"@en .

nmd:LocalAdminUnit
    a          owl:Class ;
    rdfs:label "Local Admin Unit"@en .


#############
# PROPERTIES
#############
nmd:hasIdentifier
    a            owl:ObjectProperty ;
    rdfs:domain  nmo:Coin ;
    rdfs:range   nmd:Identifier ;
    rdfs:label   "has identifier"@en ;
    rdfs:comment "The person who identified the numismatic object"@en .

nmd:hasLocalAdminUnit
    a           owl:ObjectProperty ;
    rdfs:domain nmo:Coin ;
    rdfs:range  nmd:LocalAdminUnit ;
    rdfs:label "has local admin unit"@en .