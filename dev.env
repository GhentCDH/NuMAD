# Database configuration
DB_USER=numad
DB_PASS=numad
DB_NAME=numad
DB_HOST=localhost

# Ontop configuration
ONTOP_DB_URL=jdbc:postgresql://db:5432/$DB_NAME
ONTOP_DB_USER=$DB_USER
ONTOP_DB_PASSWORD=$DB_PASS

ONTOP_ONTOLOGY_FILE=/opt/ontop/input/ontology.ttl
ONTOP_MAPPING_FILE=/opt/ontop/input/mapping.ttl
ONTOP_PROPERTIES_FILE=/opt/ontop/input/ontop.properties

# ONTOP_PORTAL_FILE=/opt/ontop/input/university-complete.portal.toml

ONTOP_CORS_ALLOWED_ORIGINS="*"

ONTOP_DEV_MODE="true"
ONTOP_LAZY_INIT="true"

# Sampo configuration
API_URL=http://localhost:3001/api/v1
SPARQL_ENDPOINT=http://localhost:8080/sparql