# Database configuration
DB_USER=numad
DB_PASS=numad
DB_NAME=numad
DB_HOST=numad-db

# Ontop configuration
ONTOP_DB_URL=jdbc:postgresql://db:5432/$DB_NAME
ONTOP_DB_USER=$DB_USER
ONTOP_DB_PASSWORD=$DB_PASS
ONTOP_JDBC_DRIVER=org.postgresql.Driver

ONTOP_ONTOLOGY_FILE=/opt/ontop/input/ontology.ttl
ONTOP_MAPPING_FILE=/opt/ontop/input/mapping.ttl
ONTOP_PROPERTIES_FILE=/opt/ontop/input/ontop.properties

ONTOP_CORS_ALLOWED_ORIGINS="*"

ONTOP_DEV_MODE="true"
ONTOP_LAZY_INIT="true"


# Kottster configuration

PORT=5480
HOST=0.0.0.0

VITE_DOCKER_MODE=true

DATABASE_URL=postgres://$DB_USER:$DB_PASS@$DB_HOST:5432/$DB_NAME
KOTTSTER_SECRET_KEY=your-secret-key-here
KOTTSTER_JWT_SECRET_SALT=your-jwt-salt-here
KOTTSTER_API_TOKEN=your-api-token-here
KOTTSTER_ROOT_USERNAME=admin
KOTTSTER_ROOT_USER_PASSWORD=admin
KOTTSTER_IDENTITY_DATABASE_PATH=/app.db


# Sampo configuration
API_URL=http://localhost:3001/api/v1
SPARQL_ENDPOINT=http://localhost:8080/sparql